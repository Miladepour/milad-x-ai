# Secret admin URL path (no password — login uses Supabase Auth)
ADMIN_PATH_SEGMENT=your-secret-admin-path

# Canonical site URL (SEO, sitemap, hreflang)
NEXT_PUBLIC_SITE_URL=https://www.mxaiacademy.com

# Supabase — Dashboard → Project Settings → API
# URL must be the Project URL (https://YOUR_REF.supabase.co), NOT a key.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
