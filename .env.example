# Secret admin URL path (no password — login uses Supabase Auth)
ADMIN_PATH_SEGMENT=your-secret-admin-path

# Canonical site URL (SEO, sitemap, hreflang)
NEXT_PUBLIC_SITE_URL=https://www.mxaiacademy.com

# Google Search Console verification (optional — falls back to built-in default)
GOOGLE_SITE_VERIFICATION=

# Cloudflare Turnstile — https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Resend — https://resend.com (student invite & access emails)
RESEND_API_KEY=
EMAIL_FROM=MX AI Academy <hello@mxaiacademy.com>
# Webhook signing secret from Resend → Webhooks → your endpoint (whsec_…)
RESEND_WEBHOOK_SECRET=

# Supabase — Dashboard → Project Settings → API
# URL must be the Project URL (https://YOUR_REF.supabase.co), NOT a key.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Bunny Stream — Stream library → API (for CDN/HLS URLs without library ID in the link)
BUNNY_STREAM_LIBRARY_ID=
# Stream library → Security → Embed view token key (only if token auth is enabled)
BUNNY_STREAM_TOKEN_KEY=

# LinkedIn auto-post (certificate image + text) — https://www.linkedin.com/developers/
# Redirect URL must be: {SITE_URL}/api/members/linkedin/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_API_VERSION=202601
# LINKEDIN_REDIRECT_URI=

# Completion certificates (optional)
CERTIFICATE_SIGNATORY_NAME=Milad EP
CERTIFICATE_ORGANIZATION_NAME=MX AI Academy
# Plain-text fallback for LinkedIn (used only if ORGANIZATION_ID is not set)
CERTIFICATE_LINKEDIN_ORGANIZATION_NAME=MX AI ACADEMY
# Numeric ID from linkedin.com/company/12345678/admin/ — auto-selects your company page
CERTIFICATE_LINKEDIN_ORGANIZATION_ID=
CERTIFICATE_SIGNATURE_IMAGE_URL=https://sayclick.co.uk/wp-content/uploads/2026/06/milad-sign-for-certificate.png
